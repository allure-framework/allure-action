{
  "name": "allure-action",
  "version": "0.0.0",
  "description": "Official Allure Report Github Action",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "dist/index.js",
  "scripts": {
    "audit": "yarn npm audit --all --recursive",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "run-s lint:oxlint lint:oxfmt",
    "lint:oxlint": "allure check --name='oxlint' --output='./out/allure-results' -- oxlint src test",
    "lint:oxfmt": "allure check --name='oxfmt' --output='./out/allure-results' -- oxfmt --check src test package.json",
    "format": "run-s format:oxlint format:oxfmt",
    "format:oxlint": "allure check --name='oxlint' --output='./out/allure-results' -- oxlint --fix src test",
    "format:oxfmt": "allure check --name='oxfmt' --output='./out/allure-results' -- oxfmt src test package.json",
    "package": "yarn clean && yarn build",
    "test": "allure run -- yarn run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "report": "allure generate ./out/allure-results",
    "report:open": "allure open ./out/allure-report"
  },
  "resolutions": {
    "axois": "^1.15.0",
    "ip-address": "10.1.1",
    "brace-expansion": "5.0.6",
    "dompurify": "3.4.11",
    "form-data": "4.0.6",
    "tar": "7.5.16",
    "undici": "6.27.0",
    "vite": "8.0.16"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/glob": "^0.7.0",
    "@actions/io": "^3.0.2",
    "d3-shape": "^3.2.0",
    "fast-glob": "^3.3.3",
    "lodash.chunk": "^4.2.0"
  },
  "devDependencies": {
    "@allurereport/core-api": "^3.13.1",
    "@allurereport/plugin-api": "^3.13.1",
    "@allurereport/plugin-awesome": "^3.13.1",
    "@allurereport/plugin-testops": "^3.13.1",
    "@types/d3-shape": "^3",
    "@types/lodash.chunk": "^4",
    "@types/node": "^26.0.0",
    "@vitest/runner": "^4.1.9",
    "@vitest/snapshot": "^4.1.9",
    "allure": "^3.13.1",
    "allure-vitest": "^3.10.1",
    "lefthook": "^2.1.9",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "rollup-plugin-license": "^3.7.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "yarn@4.13.0"
}
